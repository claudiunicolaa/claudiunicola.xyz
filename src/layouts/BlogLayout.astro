---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const { title, description, currentPage } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/posts/style.css">
    <slot name="head" />
  </Fragment>

  <a href="#main-content" class="skip-to-content">Skip to content</a>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="brand">Claudiu Nicola</a>
      <nav aria-label="Site navigation">
        <a href="/">Home</a>
        <a href="/posts/" aria-current={currentPage === 'blog' ? 'page' : undefined}>Blog</a>
      </nav>
    </div>
  </header>

  <slot />

  <footer>&copy; {new Date().getFullYear()} Claudiu Nicola. All rights reserved.</footer>
</BaseLayout>
