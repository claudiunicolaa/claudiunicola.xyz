---
import BlogLayout from './BlogLayout.astro';
import { formatDateHuman, formatDateISO } from '../utils/dates';
import { tagSlug } from '../utils/tags';

interface Props {
  title: string;
  date: Date;
  summary: string;
  tags: string[];
  keywords?: string[];
  og_image?: string;
  readingTime: number;
  slug: string;
}

const { title, date, summary, tags, keywords, og_image, readingTime, slug } = Astro.props;
const canonicalUrl = `https://claudiunicola.xyz/posts/${slug}/`;
const author = 'Claudiu Nicola';
const keywordsStr = keywords?.join(', ') || tags.join(', ');
---

<BlogLayout title={`${title} — ${author}`} description={summary} currentPage="blog">
  <Fragment slot="head">
    {keywordsStr && <meta name="keywords" content={keywordsStr} />}
    <meta name="author" content={author} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={summary} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Claudiu Nicola" />
    {og_image && <meta property="og:image" content={og_image} />}
    <meta property="article:published_time" content={date.toISOString()} />
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={og_image ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={summary} />
    {og_image && <meta name="twitter:image" content={og_image} />}

    <!-- JSON-LD BlogPosting -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description: summary,
      url: canonicalUrl,
      datePublished: date.toISOString(),
      dateModified: date.toISOString(),
      inLanguage: 'en',
      author: { '@type': 'Person', name: author, url: 'https://claudiunicola.xyz' },
      publisher: { '@type': 'Person', name: author },
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
      ...(keywordsStr ? { keywords: keywordsStr } : {}),
      ...(og_image ? { image: og_image } : {}),
    })} />

    <link rel="alternate" type="application/rss+xml" title={`${author} — Blog`} href="https://claudiunicola.xyz/posts/feed.xml" />
  </Fragment>

  <main id="main-content">
    <article>
      <header class="post-header">
        <h1>{title}</h1>
        <div class="post-meta">
          <time datetime={formatDateISO(date)}>{formatDateHuman(date)}</time>
          {readingTime && (
            <>
              <span class="meta-sep">&middot;</span>
              <span class="reading-time">{readingTime} min read</span>
            </>
          )}
          {tags.length > 0 && (
            <>
              <span class="meta-sep">&middot;</span>
              <span class="post-tags">
                {tags.map((tag) => (
                  <a href={`/posts/tags/${tagSlug(tag)}/`} class="tag-badge">{tag}</a>
                ))}
              </span>
            </>
          )}
        </div>
      </header>
      <slot />
      <a href="/posts/" class="back-link">&larr; Back to all posts</a>
    </article>
  </main>
</BlogLayout>
