---
import BaseLayout from '../layouts/BaseLayout.astro';
import resume from '../../resume.json';

const basics = resume.basics;
const work = resume.work;
const volunteer = resume.volunteer;
const education = resume.education;
const awards = resume.awards;
const publications = resume.publications;
const skills = resume.skills;
const languages = resume.languages;
const interests = resume.interests;

function formatDate(dateStr: string): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
}

function escapeHtml(str: string): string {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
---

<BaseLayout title="Claudiu Nicola">
  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,700|Open+Sans" rel="stylesheet" type="text/css">
    <link href="//maxcdn.bootstrapcdn.com/font-awesome/4.1.0/css/font-awesome.min.css" rel="stylesheet">
    <style>
      body {
        font-size: 62.5%;
        font-family: Montserrat;
        color: #333333;
      }
      .picture {
        border-radius: 50%;
        margin: 0 auto;
      }
      a {
        color: #333333;
        text-decoration: none;
      }
      a:visited {
        color: #4e4e4e;
      }
      a:hover {
        color: #4e4e4e;
        text-decoration: underline;
      }
      .header {
        text-align: center;
        font-size: 2em;
        margin-top: 1em;
        margin-left: 5%;
        margin-right: 5%;
      }
      h1 {
        font-size: 3em;
        margin-bottom: 0;
      }
      .profile {
        font-family: Montserrat;
        font-size: 1em;
        margin: 0;
      }
      .contact-header {
        font-weight: bold;
      }
      .label {
        margin-top: 0;
        margin-bottom: 1em;
      }
      .fa {
        font-size: 2em;
      }
      .left {
        font-size: 1em;
      }
      .main {
        margin: 0 auto;
        margin-left: 10%;
        margin-right: 10%;
        margin-bottom: 50px;
      }
      h2 {
        font-size: 3.5em;
      }
      h3 {
        font-size: 2em;
        margin-bottom: 0;
      }
      h4 {
        color: #4e4e4e;
        font-size: 1.5em;
        margin-top: 0;
      }
      .skills {
        margin-bottom: 10px;
      }
      p {
        font-family: 'Open Sans';
        font-size: 1.5em;
      }
      li {
        font-family: 'Open Sans';
        font-size: 1.5em;
      }
      .keywords-container {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
      }
      .keywords {
        background-color: #333333;
        color: #fff;
        padding: 6px 14px;
        font-size: 1.2em;
        border-radius: 20px;
        display: inline-block;
      }
      blockquote {
        margin: 2em 10px;
        padding: 1em 10px;
        border-left: 10px solid #edf0f5;
        font-family: 'Open Sans';
        font-size: 1.5em;
      }
      blockquote .name {
        font-weight: bold;
        font-family: "Montserrat";
      }
      .responsive-show {
        display: none;
      }
      @media (max-width: 1000px) {
        .header {
          font-size: 1.66em;
        }
        h2 {
          font-size: 3em;
        }
      }
      @media (max-width: 500px) {
        p {
          font-size: 1.2em;
        }
        li {
          font-size: 1.2em;
        }
        blockquote {
          font-size: 1.2em;
        }
        h2 {
          font-size: 2.3em;
        }
        .responsive-hidden {
          display: none;
          visibility: hidden;
        }
        .responsive-show {
          display: inline;
          visibility: visible;
        }
      }
    </style>
  </Fragment>

  <div class="header">
    <img src="/profile.jpg" width="75" height="75" class="picture" alt={basics.name}>
    <h1>{basics.name.toUpperCase()}</h1>
    <h3 class="label">{basics.label.toUpperCase()}</h3>
    <div class="contact-header">
      {basics.location.city}, {basics.location.region}, {basics.location.countryCode}<br>
    </div>
    <div id="contact">
      <br>
      <div class="contact-header">
        EMAIL <span class="responsive-hidden">&bull;</span> <span class="responsive-show"><br></span><a href={`mailto:${basics.email}`} target="_blank">{basics.email}</a> <span class="responsive-show"><br><br></span>
      </div>
    </div>
    <br>
    <div id="profiles">
      <div class="contact-header">PROFILES</div><br>
      {basics.profiles.map((p) => (
        <p class="profile"><a href={p.url} target="_blank" class="profile">{p.network}</a></p>
      ))}
      <p class="profile"><a href="/Claudiu_Nicola_Resume.pdf" download class="profile">Resume PDF</a></p>
    </div>
  </div>

  <div class="main">
    <div id="about">
      <h2><i class="fa fa-user left"></i> ABOUT</h2>
      <p>{basics.summary}</p>
    </div>

    <div id="work">
      <h2><i class="fa fa-suitcase left"></i> WORK EXPERIENCE</h2>
      {work.map((job) => (
        <div class="job">
          <h3>{job.position}, {job.company}</h3>
          <h4>{formatDate(job.startDate)} - {job.endDate ? formatDate(job.endDate) : 'Present'}</h4>
          <p>{job.summary}</p>
          {job.highlights && job.highlights.length > 0 && (
            <>
              <h4>HIGHLIGHTS</h4>
              <ul>
                {job.highlights.map((h) => <li set:html={escapeHtml(h)} />)}
              </ul>
            </>
          )}
        </div>
      ))}
    </div>

    <div id="volunteer">
      <h2><i class="fa fa-child left"></i> VOLUNTEER WORK</h2>
      {volunteer.map((v) => (
        <>
          <h3>{v.position}, {v.organization}</h3>
          <h4>{formatDate(v.startDate)} - {v.endDate ? formatDate(v.endDate) : ''}</h4>
          <p>{v.summary}{v.website && <><br><a href={v.website} target="_blank">{v.website}</a></>}</p>
        </>
      ))}
    </div>

    <div id="skills">
      <h2><i class="fa fa-tasks left"></i> SKILLS</h2>
      {skills.map((s) => (
        <>
          <h3 class="skills">{s.name}</h3>
          <div class="keywords-container">
            {s.keywords.map((k) => <span class="keywords" set:html={escapeHtml(k)} />)}
          </div>
        </>
      ))}
    </div><br>

    <div id="education">
      <h2><i class="fa fa-graduation-cap left"></i> EDUCATION</h2>
      {education.map((e) => (
        <>
          <h3>{e.studyType}, {e.area} - {e.institution}</h3>
          <h4>{formatDate(e.startDate)} - {formatDate(e.endDate)}</h4>
          {e.courses && e.courses.length > 0 && (
            <>
              <h4>COURSES</h4>
              <ul>
                {e.courses.map((c) => <li>{c}</li>)}
              </ul>
            </>
          )}
        </>
      ))}
    </div>

    <div id="awards">
      <h2><i class="fa fa-trophy left"></i> AWARDS</h2>
      {awards.map((a) => (
        <>
          <h3>{a.title} - {a.awarder}</h3>
          <h4>{new Date(a.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' })}</h4>
          {a.summary && <p>{a.summary}</p>}
        </>
      ))}
    </div>

    <div id="publications">
      <h2><i class="fa fa-book left"></i> PUBLICATIONS</h2>
      {publications.map((pub) => (
        <>
          <h3>{pub.name}</h3>
          <h4>{new Date(pub.releaseDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' })}</h4>
          <p>{pub.summary}<br><a href={pub.website} target="_blank">{pub.website}</a></p>
        </>
      ))}
    </div>

    <div id="interests">
      <h2><i class="fa fa-star left"></i> INTERESTS</h2>
      {interests.map((i) => (
        <h3 class="skills">{i.name}</h3>
      ))}
    </div>

    <div id="languages">
      <h2><i class="fa fa-language left"></i> LANGUAGES</h2>
      {languages.map((l) => (
        <>
          <h3>{l.language}</h3>
          <h4>Fluency: {l.fluency}</h4>
        </>
      ))}
    </div>
  </div>
</BaseLayout>
