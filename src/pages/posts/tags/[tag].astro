---
import { getCollection } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { formatDateHuman, formatDateISO } from '../../../utils/dates';
import { tagSlug } from '../../../utils/tags';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const tagMap = new Map<string, typeof allPosts>();

  for (const post of allPosts) {
    for (const rawTag of post.data.tags) {
      const tag = rawTag.trim().toLowerCase();
      if (!tag) continue;
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(post);
    }
  }

  return [...tagMap.entries()].map(([tag, posts]) => ({
    params: { tag: tagSlug(tag) },
    props: {
      tag,
      posts: posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;
const slug = tagSlug(tag);
const canonicalUrl = `https://claudiunicola.xyz/posts/tags/${slug}/`;
const postCount = posts.length;
const singlePost = postCount === 1;
const description = `${postCount} article${singlePost ? '' : 's'} tagged with \u201c${tag}\u201d — software engineering, backend development, and more by Claudiu Nicola.`;
---

<BlogLayout title={`Posts tagged "${tag}" — Claudiu Nicola`} description={description}>
  <Fragment slot="head">
    <meta name="author" content="Claudiu Nicola" />
    <meta name="keywords" content={`${tag}, software engineering, backend development, Claudiu Nicola`} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`Posts tagged "${tag}" — Claudiu Nicola`} />
    <meta property="og:description" content={`${postCount} article${singlePost ? '' : 's'} tagged with \u201c${tag}\u201d by Claudiu Nicola.`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Claudiu Nicola" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`Posts tagged "${tag}" — Claudiu Nicola`} />
    <meta name="twitter:description" content={`${postCount} article${singlePost ? '' : 's'} tagged with \u201c${tag}\u201d by Claudiu Nicola.`} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: `Posts tagged "${tag}"`,
      description: `Articles tagged with ${tag} by Claudiu Nicola`,
      url: canonicalUrl,
      inLanguage: 'en',
      author: {
        '@type': 'Person',
        name: 'Claudiu Nicola',
        url: 'https://claudiunicola.xyz',
      },
      breadcrumb: {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Blog', item: 'https://claudiunicola.xyz/posts/' },
          { '@type': 'ListItem', position: 2, name: tag, item: canonicalUrl },
        ],
      },
    })} />

    <link rel="alternate" type="application/rss+xml" title="Claudiu Nicola — Software Engineering Blog" href="https://claudiunicola.xyz/posts/feed.xml" />
  </Fragment>

  <main id="main-content" class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/posts/">Blog</a>
      <span class="breadcrumb-sep" aria-hidden="true">/</span>
      <span aria-current="page">{tag}</span>
    </nav>

    <div class="blog-intro">
      <h1>Posts tagged <span class="tag-label">{tag}</span></h1>
      <span class="post-count-badge">
        {postCount} article{singlePost ? '' : 's'}
      </span>
    </div>

    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/posts/${post.id}/`}>
              <div class="meta">
                <time datetime={formatDateISO(post.data.date)}>
                  {formatDateHuman(post.data.date)}
                </time>
              </div>
              <h2>{post.data.title}</h2>
              {post.data.summary && <p class="summary">{post.data.summary}</p>}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No posts found for this tag.</p>
    )}

    <a href="/posts/" class="back-link">&larr; Back to all posts</a>
  </main>
</BlogLayout>
