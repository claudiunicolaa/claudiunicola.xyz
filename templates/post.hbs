<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{title}} — {{author}}</title>
  <meta name="description" content="{{summary}}">
  <meta name="author" content="{{author}}">
  {{#if keywords}}<meta name="keywords" content="{{keywords}}">{{/if}}
  <link rel="canonical" href="{{canonicalUrl}}">

  <!-- Open Graph -->
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{title}}">
  <meta property="og:description" content="{{summary}}">
  <meta property="og:url" content="{{canonicalUrl}}">
  <meta property="og:site_name" content="Claudiu Nicola">
  {{#if og_image}}<meta property="og:image" content="{{og_image}}">{{/if}}
  <meta property="article:published_time" content="{{isoDate date}}">
  {{#each tags}}<meta property="article:tag" content="{{this}}">{{/each}}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="{{#if og_image}}summary_large_image{{else}}summary{{/if}}">
  <meta name="twitter:title" content="{{title}}">
  <meta name="twitter:description" content="{{summary}}">
  {{#if og_image}}<meta name="twitter:image" content="{{og_image}}">{{/if}}

  <!-- JSON-LD BlogPosting structured data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{jsonEscape title}}",
    "description": "{{jsonEscape summary}}",
    "url": "{{jsonEscape canonicalUrl}}",
    "datePublished": "{{isoDate date}}",
    "dateModified": "{{isoDate date}}",
    "inLanguage": "en",
    "author": {
      "@type": "Person",
      "name": "{{jsonEscape author}}",
      "url": "{{jsonEscape baseUrl}}"
    },
    "publisher": {
      "@type": "Person",
      "name": "{{jsonEscape author}}"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{jsonEscape canonicalUrl}}"
    }{{#if keywords}},
    "keywords": "{{jsonEscape keywords}}"{{/if}}{{#if og_image}},
    "image": "{{jsonEscape og_image}}"{{/if}}
  }
  </script>

  <link rel="alternate" type="application/rss+xml" title="{{author}} — Blog" href="{{baseUrl}}/posts/feed.xml">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{baseUrl}}/posts/style.css">
</head>
<body>
  <a href="#main-content" class="skip-to-content">Skip to content</a>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="{{baseUrl}}/" class="brand">Claudiu Nicola</a>
      <nav aria-label="Site navigation">
        <a href="{{baseUrl}}/">Home</a>
        <a href="{{baseUrl}}/posts/" aria-current="page">Blog</a>
      </nav>
    </div>
  </header>
  <main id="main-content">
    <article>
      <header class="post-header">
        <h1>{{title}}</h1>
        <div class="post-meta">
          <time datetime="{{isoDate date}}">{{formatDate date}}</time>
          {{#if readingTime}}<span class="meta-sep">&middot;</span><span class="reading-time">{{readingTime}} min read</span>{{/if}}
          {{#if tags}}<span class="meta-sep">&middot;</span><span class="post-tags">{{#each tags}}<a href="{{../baseUrl}}/posts/tags/{{tagSlugHelper this}}/" class="tag-badge">{{this}}</a>{{/each}}</span>{{/if}}
        </div>
      </header>
      {{{content}}}
      <a href="{{baseUrl}}/posts/" class="back-link">&larr; Back to all posts</a>
    </article>
  </main>
  <footer>&copy; {{year}} Claudiu Nicola. All rights reserved.</footer>
</body>
</html>
